# ── AgentShield Span Bridge Configuration ──
# Copy to .env and fill in your values.

# AgentShield identity (must match what agent-runtime registers with)
AGENTSHIELD_AGENT_ID=hermes-vm-agent-001
AGENTSHIELD_FAMILY_GROUP_ID=default

# ClickHouse connection (AgentShield's own ClickHouse, not Langtrace's)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=agentshield
CLICKHOUSE_PASSWORD=<set-your-password>

# AgentShield management-server
MANAGEMENT_SERVER_URL=http://localhost:8080

# Polling
POLL_INTERVAL_SECS=30
BATCH_SIZE=100
